# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*
secrets.local.json
# GCP service-account keys + any other credential files dropped here. The
# directory itself is intentionally untracked so a key never leaks via
# `git add .`. Anchored to repo root so we don't accidentally hide
# src/secrets/ (the scoped-secrets module).
/secrets/

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# graphify knowledge graph outputs (local, regenerated by post-commit hook)
graphify-out/
