[Unit]
Description=Vatedge dev-agent (NanoClaw v2) host
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple
User=devagent
Group=docker
WorkingDirectory=/opt/vatedge-dev-agent

# Runtime config. Secrets are NOT here — they are fetched from GCP Secret
# Manager at boot (SECRETS_BACKEND=gcp) via the VM's attached service account.
Environment=NODE_ENV=production
Environment=SECRETS_BACKEND=gcp
Environment=GCP_PROJECT=vatedge-prod
Environment=CLAUDE_MEM_PLUGIN_DIR=/mnt/dev-agent-data/claude-mem
Environment=MAX_CONCURRENT_CONTAINERS=3
Environment=CONTAINER_TIMEOUT=1800000
Environment=TZ=Europe/Brussels

# Wake-on-message model (see deploy/slack-gateway/README.md). With
# SLACK_GATEWAY_SUBSCRIPTION set, inbound Slack events are pulled from Pub/Sub
# (the slack-gateway Cloud Function publishes them) instead of Socket Mode, so
# the SLACK_APP_TOKEN secret must be removed/unset. IDLE_STOP_MINUTES stops this
# VM after that many minutes idle; the gateway wakes it on the next event.
Environment=SLACK_GATEWAY_SUBSCRIPTION=dev-agent-slack-events-sub
Environment=IDLE_STOP_MINUTES=15

ExecStart=/usr/bin/node /opt/vatedge-dev-agent/dist/index.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
